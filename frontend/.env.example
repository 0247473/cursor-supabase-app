# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and contains real secrets.
#
# Where to find each value:
# - VITE_SUPABASE_URL: Supabase Dashboard > Project Settings > API > Project URL
# - VITE_SUPABASE_KEY: Supabase Dashboard > Project Settings > API > anon public key
# - VITE_ML_API_URL: Your deployed ML API URL (e.g. http://localhost:8000 for local dev)
# - VITE_APP_TITLE: Display name for your app

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_KEY=your-anon-public-key-here
VITE_ML_API_URL=http://localhost:8000
VITE_APP_TITLE=My Data App
